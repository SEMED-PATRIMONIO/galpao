<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>SEMED | Gestão de Contratos e Acessos</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-slate-100 antialiased font-sans text-slate-800">

    <div class="flex h-screen overflow-hidden" 
         x-data="{ 
            abaAtual: 'alertas', 
            filtroTexto: '',
            idSelecionado: null,
            filtroAlerta: 'todos', 
            filtroDataInicio: '',
            filtroDataFim: '',
            modalContratoOpen: false,
            modalLiquidarOpen: false,
            modalUsuarioOpen: false,
            modalSetorOpen: false,
            modalCategoriaOpen: false, 
            modalFornecedorOpen: false,
            modalFornecedorEditarOpen: false,
            modalCategoriaEditarOpen: false,
            modalUsuarioEditarOpen: false,
            modalSetorEditarOpen: false,
            modalContratoEditarOpen: false,
            modalMinhaSenhaOpen: false,
            formContrato: { fornecedor_id: '', categoria_id: '', numero_contrato: '', objeto_resumido: '', valor_total: '', data_inicio: '', vigencia_meses: '', periodicidade_pagamento: 'Mensal', setor_id: '' },
            formLiquidar: { id: '', numero_contrato: '', valor_previsto: '', data_pagamento: '', valor_pago: '', juros_pagos: 0 },
            init() { this.$watch('abaAtual', value => this.idSelecionado = null) }
         }">

        <aside class="w-56 bg-slate-900 text-slate-300 flex flex-col h-screen shrink-0 border-r border-slate-800">
            <div class="p-3 flex items-center justify-between bg-white h-16 border-b border-slate-200 text-slate-900">
                <div class="flex items-center space-x-2">
                    <img src="/logap.png" alt="SEMED" class="h-9 w-auto object-contain">
                </div>
                <a href="/logout" 
                   class="flex items-center justify-center w-8 h-8 rounded-lg text-rose-600 hover:bg-rose-50 border border-slate-200 transition-all shadow-xs" 
                   title="Sair do Sistema">
                    <i class="fa-solid fa-right-from-bracket text-sm"></i>
                </a>
            </div>
            
            <div class="p-3 bg-slate-800/40 border-b border-slate-800/80 text-[11px] flex items-center justify-between">
                <div class="truncate pr-1">
                    <p class="text-slate-300 truncate">Usuário: <strong class="text-white"><%= usuarioLogado.nome %></strong></p>
                    <p class="text-slate-400 mt-0.5">Perfil: <span class="px-1.5 py-0.2 bg-sky-950 text-sky-300 rounded border border-sky-800 font-bold text-[9px] uppercase"><%= usuarioLogado.perfil %></span></p>
                </div>
                <button @click="modalMinhaSenhaOpen = true" 
                        class="w-7 h-7 bg-slate-800 hover:bg-slate-700 hover:text-amber-400 border border-slate-700 rounded-md flex items-center justify-center transition-colors shrink-0 text-slate-400" 
                        title="Alterar minha senha">
                    <i class="fa-solid fa-key text-[11px]"></i>
                </button>
            </div>

            <nav class="p-2 space-y-1 flex-1 text-xs font-bold tracking-wide">
                <button @click="abaAtual = 'alertas'" :class="abaAtual === 'alertas' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-triangle-exclamation text-base w-5 text-center text-amber-400"></i> <span>Alertas</span>
                </button>

                <button @click="abaAtual = 'contratos'" :class="abaAtual === 'contratos' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-file-signature text-base w-5 text-center text-sky-400"></i> <span>Contratos</span>
                </button>

                <% if (usuarioLogado.perfil !== 'VISUALIZADOR') { %>
                <button @click="abaAtual = 'fornecedores'" :class="abaAtual === 'fornecedores' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-truck-field text-base w-5 text-center text-indigo-400"></i> <span>Fornecedores</span>
                </button>

                <button @click="abaAtual = 'categorias'" :class="abaAtual === 'categorias' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-tags text-base w-5 text-center text-teal-400"></i> <span>Categorias</span>
                </button>
                <% } %>

                <% if (usuarioLogado.perfil !== 'VISUALIZADOR') { %>
                <button @click="abaAtual = 'usuarios'" :class="abaAtual === 'usuarios' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-users text-base w-5 text-center text-emerald-400"></i> <span>Usuários</span>
                </button>
                <% } %>

                <button @click="abaAtual = 'historico'" :class="abaAtual === 'historico' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-clock-rotate-left text-base w-5 text-center text-slate-400"></i> <span>Histórico</span>
                </button>

                <button @click="abaAtual = 'configuracoes'" :class="abaAtual === 'configuracoes' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-gear text-base w-5 text-center text-slate-400"></i> <span>Configurações</span>
                </button>

                <% if (usuarioLogado.perfil === 'ADMIN') { %>
                <button @click="abaAtual = 'setores'" :class="abaAtual === 'setores' ? 'bg-sky-800 text-white shadow-xs' : 'text-slate-400 hover:bg-slate-800/60'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg text-left transition-all">
                    <i class="fa-solid fa-building-user text-base w-5 text-center text-violet-400"></i> <span>Estrutura</span>
                </button>
                <% } %>
            </nav>
            <div class="p-3 border-t border-slate-850 bg-slate-950/20 text-center text-[10px] text-slate-500 font-medium tracking-wide leading-relaxed">
                Desenvolvido pela Subsecretaria<br>Adjunta de Inovação e Tecnologia
            </div>
        </aside>

        <div class="flex-1 flex flex-col overflow-hidden">
            <header class="bg-white h-16 border-b border-slate-200 flex items-center justify-between px-6 shadow-sm">
                <h2 class="text-xs font-bold uppercase tracking-wider text-slate-600" x-text="'Painel Administrativo > ' + abaAtual"></h2>
                
                <div class="flex items-center space-x-2">
                    <div x-show="idSelecionado !== null" x-transition>
                        <button @click="
                            if(abaAtual === 'fornecedores') { $dispatch('abrir-editar-fornecedor', { id: idSelecionado }); }
                            if(abaAtual === 'categorias') { $dispatch('abrir-editar-categoria', { id: idSelecionado }); }
                            if(abaAtual === 'usuarios') { $dispatch('abrir-editar-usuario', { id: idSelecionado }); }
                            if(abaAtual === 'setores') { $dispatch('abrir-editar-setor', { id: idSelecionado }); }
                            if(abaAtual === 'contratos') { $dispatch('abrir-editar-contrato', { id: idSelecionado }); }
                        " class="bg-amber-500 hover:bg-amber-600 text-white text-[11px] font-bold px-4 py-2 rounded-lg shadow flex items-center gap-1.5 transition-all">
                            <i class="fa-solid fa-pen-to-square"></i> Editar Registro
                        </button>
                    </div>

                    <div>
                        <button x-show="abaAtual === 'contratos' && '<%= usuarioLogado.perfil %>' !== 'VISUALIZADOR'" @click="modalContratoOpen = true" class="bg-sky-800 hover:bg-sky-900 text-white text-[11px] font-bold px-4 py-2 rounded-lg shadow flex items-center gap-1.5 transition-all">
                            <i class="fa-solid fa-file-circle-plus"></i> Novo Contrato
                        </button>
                        <button x-show="abaAtual === 'fornecedores'" @click="modalFornecedorOpen = true" class="bg-amber-600 hover:bg-amber-700 text-white text-[11px] font-bold px-4 py-2 rounded-lg shadow flex items-center gap-1.5 transition-all">
                            <i class="fa-solid fa-truck-field"></i> Novo Fornecedor
                        </button>
                        <button x-show="abaAtual === 'categorias'" @click="modalCategoriaOpen = true" class="bg-teal-600 hover:bg-teal-700 text-white text-[11px] font-bold px-4 py-2 rounded-lg shadow flex items-center gap-1.5 transition-all">
                            <i class="fa-solid fa-tag"></i> Nova Categoria
                        </button>
                        <button x-show="abaAtual === 'usuarios'" @click="modalUsuarioOpen = true" class="bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] font-bold px-4 py-2 rounded-lg shadow flex items-center gap-1.5 transition-all">
                            <i class="fa-solid fa-user-gear"></i> Novo Operador
                        </button>
                        <button x-show="abaAtual === 'setores'" @click="modalSetorOpen = true" class="bg-indigo-600 hover:bg-indigo-700 text-white text-[11px] font-bold px-4 py-2 rounded-lg shadow flex items-center gap-1.5 transition-all">
                            <i class="fa-solid fa-building"></i> Novo Setor
                        </button>
                    </div>
                </div>
            </header>

            <main class="flex-1 overflow-y-auto p-6">
                
                <div x-show="abaAtual === 'contratos'" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200 uppercase tracking-wider">
                                <th class="p-4">Nº Contrato</th>
                                <th class="p-4">Fornecedor</th>
                                <th class="p-4">Categoria</th>
                                <th class="p-4 text-right">Valor Global</th>
                                <th class="p-4 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% contratos.forEach(c => { %>
                            <tr @click="idSelecionado = (idSelecionado === <%= c.id %> ? null : <%= c.id %>)"
                                :class="idSelecionado === <%= c.id %> ? 'bg-sky-100/80 font-bold border-l-4 border-sky-600' : 'hover:bg-slate-50/60'"
                                class="transition-all cursor-pointer">
                                <td class="p-4 font-bold text-slate-900"><%= c.numero_contrato %></td>
                                <td class="p-4 font-semibold text-slate-700"><%= c.fornecedor %></td>
                                <td class="p-4 text-slate-500"><%= c.categoria %></td>
                                <td class="p-4 text-right font-mono font-bold text-slate-900">R$ <%= parseFloat(c.valor_total).toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                                <td class="p-4 text-center">
                                    <span class="text-slate-400 italic text-[11px]">Online</span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                
                <div x-show="abaAtual === 'alertas'" class="space-y-6 animate-fade-in">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        
                        <div @click="filtroAlerta = (filtroAlerta === 'expiracao' ? 'todos' : 'expiracao')"
                             :class="filtroAlerta === 'expiracao' ? 'ring-2 ring-amber-500 bg-amber-50 border-amber-300' : 'bg-white hover:shadow-md border-slate-200'"
                             class="p-5 rounded-2xl border shadow-xs cursor-pointer transition-all flex items-center justify-between select-none">
                            <div class="space-y-1">
                                <span class="text-xs font-bold uppercase text-slate-500 tracking-wider">Contratos a Vencer</span>
                                <h4 class="text-2xl font-black text-slate-900">
                                    <% 
                                       let countVencer = contratos.filter(c => {
                                           let dataFim = new Date(c.data_inicio);
                                           dataFim.setMonth(dataFim.getMonth() + c.vigencia_meses);
                                           let diffDias = Math.ceil((dataFim - new Date()) / (1000 * 60 * 60 * 24));
                                           return diffDias >= 0 && diffDias <= 45;
                                       }).length;
                                    %>
                                    <%= countVencer %>
                                </h4>
                                <p class="text-[10px] text-slate-400">Expiração nos próximos 45 dias</p>
                            </div>
                            <div class="w-10 h-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-600">
                                <i class="fa-solid fa-clock-history text-lg"></i>
                            </div>
                        </div>

                        <div @click="filtroAlerta = (filtroAlerta === 'parcelas' ? 'todos' : 'parcelas')"
                             :class="filtroAlerta === 'parcelas' ? 'ring-2 ring-emerald-500 bg-emerald-50 border-emerald-300' : 'bg-white hover:shadow-md border-slate-200'"
                             class="p-5 rounded-2xl border shadow-xs cursor-pointer transition-all flex items-center justify-between select-none">
                            <div class="space-y-1">
                                <span class="text-xs font-bold uppercase text-slate-500 tracking-wider">Vencimento de Parcelas</span>
                                <h4 class="text-2xl font-black text-slate-900">
                                    <%= alertasFinanceiros.length %>
                                </h4>
                                <p class="text-[10px] text-slate-400">Parcelas críticas em aberto</p>
                            </div>
                            <div class="w-10 h-10 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-600">
                                <i class="fa-solid fa-calendar-check text-lg"></i>
                            </div>
                        </div>

                        <div @click="filtroAlerta = (filtroAlerta === 'apostilamento' ? 'todos' : 'apostilamento')"
                             :class="filtroAlerta === 'apostilamento' ? 'ring-2 ring-rose-500 bg-rose-50 border-rose-300' : 'bg-white hover:shadow-md border-slate-200'"
                             class="p-5 rounded-2xl border shadow-xs cursor-pointer transition-all flex items-center justify-between select-none">
                            <div class="space-y-1">
                                <span class="text-xs font-bold uppercase text-slate-500 tracking-wider">Apostilamentos Pendentes</span>
                                <h4 class="text-2xl font-black text-rose-600">
                                    <% let countApostila = contratos.filter(c => c.necessita_apostilamento && !c.data_apostilamento).length; %>
                                    <%= countApostila %>
                                </h4>
                                <p class="text-[10px] text-rose-500/80 font-semibold">Marcados sem data preenchida</p>
                            </div>
                            <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-600 animate-pulse">
                                <i class="fa-solid fa-triangle-exclamation text-lg"></i>
                            </div>
                        </div>

                    </div>

                    <div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="p-4 bg-slate-50 border-b border-slate-200 flex items-center justify-between">
                            <div>
                                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-700 flex items-center gap-2">
                                    <i class="fa-solid fa-list-check text-sky-800"></i> Listagem Detalhada de Atenção
                                </h3>
                                <p class="text-[11px] text-slate-400 mt-0.5">
                                    Filtro Selecionado: <span class="font-bold text-sky-800 uppercase" x-text="filtroAlerta"></span>
                                </p>
                            </div>
                            <div x-show="filtroAlerta !== 'todos'">
                                <button @click="filtroAlerta = 'todos'" class="text-[10px] bg-slate-200 hover:bg-slate-300 text-slate-700 px-2.5 py-1 rounded-md font-bold transition-all">
                                    Limpar Filtro <i class="fa-solid fa-xmark ml-1"></i>
                                </button>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse text-xs">
                                <thead>
                                    <tr class="bg-slate-100/70 border-b border-slate-200 text-slate-500 font-bold uppercase tracking-wider text-[10px]">
                                        <th class="p-4">Nº Contrato</th>
                                        <th class="p-4">Fornecedor</th>
                                        <th class="p-4">Objeto Resumido</th>
                                        <th class="p-4 text-center">Tipo de Alerta</th>
                                        <th class="p-4 text-center">Ações</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 font-medium text-slate-700">
                                    <% contratos.forEach(c => { 
                                        let dataFim = new Date(c.data_inicio);
                                        dataFim.setMonth(dataFim.getMonth() + c.vigencia_meses);
                                        let diffDias = Math.ceil((dataFim - new Date()) / (1000 * 60 * 60 * 24));
                                        
                                        let isExpiracao = (diffDias >= 0 && diffDias <= 45);
                                        let isApostilaPendente = (c.necessita_apostilamento && !c.data_apostilamento);
                                    %>
                                        <tr data-expiracao="<%= isExpiracao %>" 
                                            data-apostila="<%= isApostilaPendente %>"
                                            x-show="filtroAlerta === 'todos' || 
                                                    (filtroAlerta === 'expiracao' && $el.getAttribute('data-expiracao') === 'true') || 
                                                    (filtroAlerta === 'apostilamento' && $el.getAttribute('data-apostila') === 'true')"
                                            class="hover:bg-slate-50/60 transition-all">
                                            
                                            <td class="p-4 font-mono font-bold text-slate-900"><%= c.numero_contrato %></td>
                                            <td class="p-4 font-semibold text-slate-700"><%= c.fornecedor %></td>
                                            <td class="p-4 max-w-[240px] truncate text-slate-500"><%= c.objeto_resumido %></td>
                                            
                                            <td class="p-4 text-center">
                                                <% if (isApostilaPendente) { %>
                                                    <span class="inline-flex items-center gap-1 bg-rose-100 text-rose-700 px-2.5 py-0.5 rounded-full text-[10px] font-bold border border-rose-200">
                                                        <i class="fa-solid fa-stamp text-[9px]"></i> Apostilamento Pendente
                                                    </span>
                                                <% } %>
                                                <% if (isExpiracao) { %>
                                                    <span class="inline-flex items-center gap-1 bg-amber-100 text-amber-700 px-2.5 py-0.5 rounded-full text-[10px] font-bold border border-amber-200">
                                                        <i class="fa-solid fa-hourglass-half text-[9px]"></i> Expira em <%= diffDias %> dias
                                                    </span>
                                                <% } %>
                                            </td>
                                            
                                            <td class="p-4 text-center">
                                                <button @click="$dispatch('abrir-editar-contrato', { id: <%= c.id %> })" 
                                                        class="bg-slate-100 hover:bg-amber-500 hover:text-white text-slate-600 font-bold px-3 py-1.5 rounded-lg transition-all text-[10px] flex items-center gap-1 mx-auto shadow-xs border border-slate-200">
                                                    <i class="fa-solid fa-pen-to-square"></i> Tratar
                                                </button>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                </div>

                <div x-show="abaAtual === 'fornecedores'" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200 uppercase"><th class="p-4">Razão Social</th><th class="p-4">CNPJ</th><th class="p-4">Contato</th><th class="p-4">Telefone</th></tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% proveedores = (typeof fornecedores !== 'undefined') ? fornecedores : [] %>
                            <% proveedores.forEach(f => { %>
                            <tr @click="idSelecionado = (idSelecionado === <%= f.id %> ? null : <%= f.id %>)"
                                :class="idSelecionado === <%= f.id %> ? 'bg-sky-100/80 font-bold border-l-4 border-sky-600' : 'hover:bg-slate-50/60'"
                                class="transition-all cursor-pointer">
                                <td class="p-4 font-bold text-slate-900"><%= f.razao_social %></td>
                                <td class="p-4 font-mono text-slate-600"><%= f.cnpj %></td>
                                <td class="p-4 text-slate-500"><%= f.contato_nome || '-' %></td>
                                <td class="p-4 font-mono text-slate-700"><%= f.telefone %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div x-show="abaAtual === 'categorias'" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200 uppercase"><th class="p-4">Identificador (ID)</th><th class="p-4">Nome da Categoria</th></tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% categorias.forEach(cat => { %>
                            <tr @click="idSelecionado = (idSelecionado === <%= cat.id %> ? null : <%= cat.id %>)"
                                :class="idSelecionado === <%= cat.id %> ? 'bg-sky-100/80 font-bold border-l-4 border-sky-600' : 'hover:bg-slate-50/60'"
                                class="transition-all cursor-pointer">
                                <td class="p-4 font-mono font-bold text-slate-400"><%= cat.id %></td>
                                <td class="p-4 font-bold text-slate-800"><%= cat.nome %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>                

                <div x-show="abaAtual === 'usuarios'" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 font-bold border-b border-slate-200 uppercase">
                                <th class="p-4">Nome Completo</th>
                                <th class="p-4">E-mail Corporativo</th>
                                <th class="p-4 text-center">Setor</th>
                                <th class="p-4 text-center">Nível Perfil</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% usuariosCadastrados.forEach(u => { %>
                            <tr @click="idSelecionado = (idSelecionado === <%= u.id %> ? null : <%= u.id %>)"
                                :class="idSelecionado === <%= u.id %> ? 'bg-sky-100/80 font-bold border-l-4 border-sky-600' : 'hover:bg-slate-50/60'"
                                class="transition-all cursor-pointer">
                                <td class="p-4 font-bold text-slate-900"><%= u.nome %></td>
                                <td class="p-4 font-semibold text-slate-600"><%= u.email %></td>
                                <td class="p-4 text-center font-bold text-indigo-700"><%= u.setor_sigla %></td>
