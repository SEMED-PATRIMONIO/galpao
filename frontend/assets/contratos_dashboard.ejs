<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Contratos</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body class="bg-slate-100 antialiased font-sans text-slate-800">

    <div class="flex h-screen overflow-hidden" 
         x-data="{ 
            abaAtual: 'contratos', 
            itemSelecionado: null, 
            filtroTexto: '', 
            filtroCategoria: '',
            modalAddOpen: false,
            verListaAlertas: false,
            filtroOrigem: '', 
            filtroLocalizacao: '',

            // Método assíncrono para despachar a declaração de ciência de prazo ao servidor
            async darCienciaAlerta(parcelaId) {
                if (!confirm('Declarar ciência do vencimento desta parcela? Ela sairá dos seus alertas visuais.')) return;
                try {
                    let res = await fetch(`/api/v2/admin-exclusivo/contratos/declarar-ciencia`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ contrato_id: parcelaId })
                    });
                    window.location.reload();
                } catch (e) {
                    alert('Erro ao processar ciência.');
                }
            }
         }">

        <aside class="w-64 bg-slate-900 text-slate-300 flex flex-col h-screen border-r border-slate-800 shrink-0">
            <div class="p-4 flex items-center space-x-3 bg-white h-16 border-b border-slate-200">
                <i class="fa-solid fa-file-contract text-sky-800 text-2xl"></i>
                <span class="font-bold text-sm tracking-wider text-slate-900 uppercase">Contratos</span>
            </div>
            
            <nav class="p-3 space-y-1 flex-1">
                <button @click="abaAtual = 'contratos'; itemSelecionado = null" :class="abaAtual === 'contratos' ? 'bg-sky-800 text-white' : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg font-medium text-sm text-left transition-all">
                    <i class="fa-solid fa-file-signature w-5 text-center text-base"></i>
                    <span>Gestão de Contratos</span>
                </button>

                <button @click="abaAtual = 'alertas'; itemSelecionado = null" :class="abaAtual === 'alertas' ? 'bg-sky-800 text-white' : 'text-slate-400 hover:bg-slate-800/50 hover:text-white'" class="w-full flex items-center space-x-3 px-3 py-2.5 rounded-lg font-medium text-sm text-left transition-all">
                    <i class="fa-solid fa-triangle-exclamation w-5 text-center text-base text-amber-400"></i>
                    <span>Vencimentos Críticos</span>
                </button>
            </nav>
            
            <div class="p-4 bg-slate-950 text-[10px] text-slate-600 text-center border-t border-slate-800 uppercase tracking-widest">
                Controle de Prazos Setoriais v2.0
            </div>
        </aside>

        <div class="flex-1 flex flex-col overflow-hidden">
            
            <header class="bg-white border-b border-slate-200 h-16 flex items-center justify-between px-6 shadow-sm shrink-0">
                <div class="flex items-center space-x-2">
                    <span class="text-xs font-bold uppercase tracking-wider text-slate-400 bg-slate-100 px-2 py-1 rounded" x-text="abaAtual === 'contratos' ? 'Painel Geral' : 'Alertas Críticos'"></span>
                </div>

                <div class="flex items-center space-x-3">
                    <div x-show="abaAtual === 'contratos'">
                        <select x-model="filtroCategoria" class="px-3 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs w-48 text-slate-700 font-medium focus:outline-none">
                            <option value="">Todas as Categorias</option>
                            <% categorias.forEach(c => { %>
                                <option value="<%= c.nome %>"><%= c.nome %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-2.5 text-slate-400">
                            <i class="fa-solid fa-magnifying-glass text-xs"></i>
                        </span>
                        <input type="text" x-model="filtroTexto" placeholder="Filtrar registros..." class="pl-8 pr-3 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs w-56 focus:outline-none focus:ring-2 focus:ring-sky-600">
                    </div>

                    <button @click="modalAddOpen = true" class="bg-sky-800 hover:bg-sky-900 text-white text-xs font-bold px-3 py-2 rounded-lg flex items-center gap-1.5 shadow transition-all">
                        <i class="fa-solid fa-plus"></i> Novo Contrato
                    </button>
                </div>
            </header>

            <main class="flex-1 overflow-y-auto p-6">
                
                <div x-show="abaAtual === 'contratos'" class="grid grid-cols-3 gap-4 text-xs font-semibold mb-6">
                    <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                        <div><p class="text-slate-400 uppercase tracking-wider mb-1">Contratos do Setor</p><h3 class="text-2xl font-bold text-slate-800"><%= contratos.length %></h3></div>
                        <div class="p-3 rounded-lg bg-slate-50 text-slate-700 text-xl"><i class="fa-solid fa-folder-closed"></i></div>
                    </div>
                    
                    <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                        <div><p class="text-slate-400 uppercase tracking-wider mb-1">Situação Operacional</p><h3 class="text-2xl font-bold text-emerald-600">Ativos</h3></div>
                        <div class="p-3 rounded-lg bg-emerald-50 text-emerald-700 text-xl"><i class="fa-solid fa-circle-check"></i></div>
                    </div>

                    <div @click="verListaAlertas = !verListaAlertas" 
                         class="p-4 rounded-xl border flex items-center justify-between shadow-sm cursor-pointer transition-all select-none"
                         :class="text-rose-700 ? 'bg-rose-50 border-rose-200 hover:bg-rose-100/60' : 'bg-white border-slate-200'">
                        <div>
                            <p class="text-rose-500 uppercase tracking-wider mb-1 font-bold flex items-center gap-1">
                                <i class="fa-solid fa-bell animate-bounce"></i> Vencimento Próximo
                            </p>
                            <h3 class="text-xl font-bold text-rose-700"><%= alertasFinanceiros.length %> pendentes</h3>
                        </div>
                        <div class="p-3 rounded-lg bg-rose-100 text-rose-700 text-xl"><i class="fa-solid fa-receipt"></i></div>
                    </div>
                </div>

                <div x-show="abaAtual === 'contratos' && verListaAlertas" x-transition class="bg-white border border-rose-200 rounded-xl p-4 mb-6 shadow-sm">
                    <h4 class="text-xs font-bold text-rose-800 uppercase tracking-wider mb-3">⚠️ Atenção Necessária nas Próximas Parcelas:</h4>
                    <div class="overflow-hidden rounded-lg border border-slate-100">
                        <table class="w-full text-left text-xs border-collapse">
                            <tr class="bg-slate-50 font-bold text-slate-500 border-b border-slate-200">
                                <td class="p-2.5">Contrato</td>
                                <td class="p-2.5">Fornecedor</td>
                                <td class="p-2.5">Vencimento</td>
                                <td class="p-2.5 text-center">Ação</td>
                            </tr>
                            <% alertasFinanceiros.forEach(p => { %>
                                <tr class="border-b border-slate-100 text-slate-700">
                                    <td class="p-2.5 font-bold"><%= p.numero_contrato %></td>
                                    <td class="p-2.5"><%= p.fornecedor %></td>
                                    <td class="p-2.5 text-rose-600 font-semibold"><%= new Date(p.data_vencimento).toLocaleDateString('pt-BR') %></td>
                                    <td class="p-2.5 text-center">
                                        <button @click="darCienciaAlerta(<%= p.id %>)" class="px-2 py-1 bg-amber-600 hover:bg-amber-700 text-white font-bold rounded text-[10px] transition-colors shadow-sm">
                                            ✔ Dar Ciência
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        </table>
                    </div>
                </div>

                <div x-show="abaAtual === 'contratos'" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 font-bold uppercase tracking-wider border-b border-slate-200">
                                <th class="p-4">Nº Contrato</th>
                                <th class="p-4">Fornecedor / Prestador</th>
                                <th class="p-4">Objeto Resumido</th>
                                <th class="p-4">Categoria</th>
                                <th class="p-4 text-center">SLA/Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% contratos.forEach(c => { %>
                            <tr class="hover:bg-slate-50/60 transition-colors"
                                x-show="filtroTexto === '' || '<%= c.numero_contrato %>'.toLowerCase().includes(filtroTexto.toLowerCase()) || '<%= c.fornecedor %>'.toLowerCase().includes(filtroTexto.toLowerCase())"
                                x-show.important="filtroCategoria === '' || '<%= c.categoria %>' === filtroCategoria">
                                <td class="p-4 font-bold text-slate-900"><%= c.numero_contrato %></td>
                                <td class="p-4 font-semibold text-slate-700"><%= c.fornecedor %></td>
                                <td class="p-4 text-slate-500 max-w-xs truncate"><%= c.objeto_resumido %></td>
                                <td class="p-4"><span class="px-2 py-0.5 rounded bg-slate-100 font-medium text-slate-600"><%= c.categoria %></span></td>
                                <td class="p-4 text-center">
                                    <span class="px-2 py-0.5 rounded text-[10px] font-bold bg-emerald-50 text-emerald-700 uppercase border border-emerald-200">Ativo</span>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div x-show="abaAtual === 'alertas'" class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="p-4 bg-amber-50 border-b border-amber-200 text-amber-800 font-semibold text-xs flex items-center gap-2">
                        <i class="fa-solid fa-circle-info text-base"></i> Cronograma de parcelas com prazo crítico (vencimento inferior a 30 dias).
                    </div>
                    <table class="w-full text-left text-xs border-collapse">
                        <thead>
                            <tr class="bg-slate-50 text-slate-600 font-bold uppercase border-b border-slate-200">
                                <th class="p-4">Contrato</th>
                                <th class="p-4">Fornecedor</th>
                                <th class="p-4">Nº Parcela</th>
                                <th class="p-4">Vencimento</th>
                                <th class="p-4 text-right">Valor Parcela</th>
                                <th class="p-4 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% alertasFinanceiros.forEach(p => { %>
                            <tr class="hover:bg-slate-50/40">
                                <td class="p-4 font-bold text-slate-800"><%= p.numero_contrato %></td>
                                <td class="p-4 font-semibold text-slate-600"><%= p.fornecedor %></td>
                                <td class="p-4 font-mono font-bold"><%= p.numero_parcela %></td>
                                <td class="p-4 text-rose-600 font-bold"><%= new Date(p.data_vencimento).toLocaleDateString('pt-BR') %></td>
                                <td class="p-4 text-right font-mono font-bold text-slate-900">R$ <%= p.valor.toLocaleString('pt-BR', {minimumFractionDigits: 2}) %></td>
                                <td class="p-4 text-center">
                                    <button @click="darCienciaAlerta(<%= p.id %>)" class="bg-amber-600 hover:bg-amber-700 text-white font-bold text-[10px] px-2.5 py-1 rounded shadow transition-all uppercase tracking-wider">
                                        Assinar Ciência
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

            </main>
        </div>
    </div>
</body>
</html>