        <div x-show="modalFornecedorOpen" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex justify-center items-center z-50 p-4">
            <div class="bg-white rounded-2xl border w-full max-w-sm p-6 shadow-2xl relative" 
                 @click.away="modalFornecedorOpen = false"
                 x-data="{
                    erroCNPJ: '',
                    dados: { razao_social: '', cnpj: '', contato_nome: '', telefone: '(21) ', email: '' },

                    aplicarMascaraCNPJ(valor) {
                        valor = valor.replace(/\D/g, ''); 
                        if (valor.length > 14) valor = valor.slice(0, 14);
                        valor = valor.replace(/^(\d{2})(\d)/, '$1.$2');
                        valor = valor.replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3');
                        valor = valor.replace(/\.(\d{3})(\d)/, '.$1/$2');
                        valor = valor.replace(/(\d{4})(\d)/, '$1-$2');
                        this.dados.cnpj = valor;
                    },

                    validarCNPJMatematico(cnpj) {
                        cnpj = cnpj.replace(/\D/g, '');
                        if (cnpj.length !== 14 || /^(\d)\1+$/.test(cnpj)) return false;
                        
                        let tamanho = cnpj.length - 2;
                        let numeros = cnpj.substring(0, tamanho);
                        let digitos = cnpj.substring(tamanho);
                        let soma = 0;
                        let pos = tamanho - 7;
                        
                        for (let i = tamanho; i >= 1; i--) {
                            soma += numeros.charAt(tamanho - i) * pos--;
                            if (pos < 2) pos = 9;
                        }
                        
                        let resultado = soma % 11 < 2 ? 0 : 11 - (soma % 11);
                        if (resultado != digitos.charAt(0)) return false;
                        
                        tamanho = tamanho + 1;
                        numeros = cnpj.substring(0, tamanho);
                        soma = 0;
                        pos = tamanho - 7;
                        for (let i = tamanho; i >= 1; i--) {
                            soma += numeros.charAt(tamanho - i) * pos--;
                            if (pos < 2) pos = 9;
                        }
                        resultado = soma % 11 < 2 ? 0 : 11 - (soma % 11);
                        return resultado == digitos.charAt(1);
                    },

                    verificarCampoCNPJ() {
                        let purificado = this.dados.cnpj.replace(/\D/g, '');
                        if (purificado.length === 14) {
                            if (!this.validarCNPJMatematico(this.dados.cnpj)) {
                                this.erroCNPJ = 'CNPJ MATEMATICAMENTE INVÁLIDO!';
                                this.dados.cnpj = '';
                                setTimeout(() => { this.erroCNPJ = ''; }, 5000);
                            }
                        }
                    },

                    tratarRazaoSocial(valor) {
                        this.dados.razao_social = valor
                            .normalize('NFD')
                            .replace(/[\u0300-\u036f]/g, '') 
                            .toUpperCase();
                    },

                    aplicarMascaraTelefone(valor) {
                        valor = valor.replace(/\D/g, '');
                        if (valor.length > 11) valor = valor.slice(0, 11);
                        if (valor.length > 6) {
                            valor = valor.replace(/^(\d{2})(\d{5})(\d{4})$/, '($1) $2-$3');
                        } else if (valor.length > 2) {
                            valor = valor.replace(/^(\d{2})(\d)/, '($1) $2');
                        } else {
                            valor = valor.replace(/^(\d*)/, '($1');
                        }
                        this.dados.telefone = valor;
                    },

                    tratarEmail(valor) {
                        let formatado = valor.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                        if (formatado.endsWith('@')) {
                            formatado += 'gmail.com';
                        }
                        this.dados.email = formatado;
                    },

                    async submeterFornecedor() {
                        try {
                            let resposta = await fetch('/fornecedores/salvar', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify(this.dados)
                            });

                            if (resposta.ok) {
                                alert('Fornecedor cadastrado com sucesso!');
                                this.dados = { razao_social: '', cnpj: '', contato_nome: '', telefone: '(21) ', email: '' };
                                modalFornecedorOpen = false;
                                window.location.reload();
                            } else {
                                alert('Erro operacional ao salvar fornecedor.');
                            }
                        } catch(e) {
                            alert('Falha de comunicação com o servidor.');
                        }
                    }
                 }">

                <div x-show="erroCNPJ" x-transition class="fixed inset-0 flex items-center justify-center z-50 bg-black/20 backdrop-blur-xs">
                    <div class="bg-rose-600 text-white font-black text-center px-6 py-4 rounded-xl shadow-2xl border border-rose-700 uppercase tracking-wider animate-bounce text-sm">
                        <i class="fa-solid fa-triangle-exclamation mr-2 text-base"></i>
                        <span x-text="erroCNPJ"></span>
                    </div>
                </div>

                <h3 class="text-sm font-bold text-slate-900 mb-4 uppercase flex items-center gap-2">
                    <i class="fa-solid fa-truck-field text-amber-600"></i> Cadastrar Fornecedor
                </h3>
                
                <form @submit.prevent="submeterFornecedor()" class="space-y-3 text-xs font-semibold text-slate-600">
                    <div class="grid grid-cols-2 gap-2">
                        <div>
                            <label class="block text-slate-500 mb-1">Razão Social</label>
                            <input type="text" 
                                   x-ref="focoInicial"
                                   x-model="dados.razao_social" 
                                   @input="tratarRazaoSocial($event.target.value)"
                                   class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg focus:outline-none text-slate-900" required>
                        </div>
                        <div>
                            <label class="block text-slate-500 mb-1">CNPJ</label>
                            <input type="text" 
                                   x-model="dados.cnpj" 
                                   @input="aplicarMascaraCNPJ($event.target.value)"
                                   @blur="verificarCampoCNPJ()"
                                   placeholder="00.000.000/0001-00" 
                                   class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg focus:outline-none text-slate-900 font-mono" required>
                        </div>
                    </div>
                    <div>
                        <label class="block text-slate-500 mb-1">Nome do Contato</label>
