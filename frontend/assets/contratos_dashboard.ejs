                idEditar = $event.detail.id;
                fetch('/fornecedores/' + idEditar)
                    .then(res => res.json())
                    .then(res => {
                        dados = { 
                            razao_social: res.razao_social, 
                            cnpj: res.cnpj, 
                            contato_nome: res.contato_nome || '', 
                            telefone: res.telefone || '(21) ', 
                            email: res.email || '' 
                        };
                        modalFornecedorEditarOpen = true;
                    });
             "
             x-data="{
                idEditar: null,
                erroCNPJ: '',
                dados: { razao_social: '', cnpj: '', contato_nome: '', telephone: '', email: '' },

                aplicarMascaraCNPJ(valor) {
                    valor = valor.replace(/\D/g, '');
                    if (valor.length > 14) valor = valor.slice(0, 14);
                    valor = valor.replace(/^(\d{2})(\d)/, '$1.$2').replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3').replace(/\.(\d{3})(\d)/, '.$1/$2').replace(/(\d{4})(\d)/, '$1-$2');
                    this.dados.cnpj = valor;
                },
                validarCNPJMatematico(cnpj) {
                    cnpj = cnpj.replace(/\D/g, ''); if (cnpj.length !== 14 || /^(\d)\1+$/.test(cnpj)) return false;
                    let tamanho = cnpj.length - 2; let numeros = cnpj.substring(0, tamanho); let digitos = cnpj.substring(tamanho); let soma = 0; let pos = tamanho - 7;
                    for (let i = tamanho; i >= 1; i--) { soma += numeros.charAt(tamanho - i) * pos--; if (pos < 2) pos = 9; }
                    let resultado = soma % 11 < 2 ? 0 : 11 - (soma % 11); if (resultado != digitos.charAt(0)) return false;
                    tamanho = tamanho + 1; numeros = cnpj.substring(0, tamanho); soma = 0; pos = tamanho - 7;
                    for (let i = tamanho; i >= 1; i--) { soma += numeros.charAt(tamanho - i) * pos--; if (pos < 2) pos = 9; }
                    resultado = soma % 11 < 2 ? 0 : 11 - (soma % 11); return resultado == digitos.charAt(1);
                },
                verificarCampoCNPJ() {
                    if (this.dados.cnpj.replace(/\D/g, '').length === 14 && !this.validarCNPJMatematico(this.dados.cnpj)) {
                        this.erroCNPJ = 'CNPJ MATEMATICAMENTE INVÁLIDO!'; this.dados.cnpj = ''; setTimeout(() => { this.erroCNPJ = ''; }, 5000);
                    }
                },
                tratarRazaoSocial(valor) { this.dados.razao_social = valor.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toUpperCase(); },
                aplicarMascaraTelefone(valor) {
                    valor = valor.replace(/\D/g, ''); if (valor.length > 11) valor = valor.slice(0, 11);
                    if (valor.length > 6) valor = valor.replace(/^(\d{2})(\d{5})(\d{4})$/, '($1) $2-$3');
                    else if (valor.length > 2) valor = valor.replace(/^(\d{2})(\d)/, '($1) $2');
                    else valor = valor.replace(/^(\d*)/, '($1');
                    this.dados.telefone = valor;
                },
                tratarEmail(valor) { 
                    let fmt = valor.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
                    if (fmt.endsWith('@')) fmt += 'gmail.com'; this.dados.email = fmt; 
                },

                async atualizarFornecedor() {
                    try {
                        let resposta = await fetch('/fornecedores/atualizar', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                idEditar: this.idEditar,
                                razao_social: this.dados.razao_social,
                                contato_nome: this.dados.contato_nome,
                                telefone: this.dados.telefone,
                                email: this.dados.email
                            })
                        });

                        if (resposta.ok) {
                            alert('Registro atualizado com sucesso!');
                            modalFornecedorEditarOpen = false;
                            idSelecionado = null;
                            window.location.reload();
                        } else {
                            let err = await resposta.json();
                            alert('Erro na validação do backend: ' + err.erro);
                        }
                    } catch(e) {
                        alert('Falha crítica de rede ao tentar atualizar o registro.');
                    }
                }
             }">

