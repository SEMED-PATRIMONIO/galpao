                            } else {
                                alert('Erro operacional ao salvar setor.');
                            }
                        } catch(e) {
                            alert('Falha de comunicação com o servidor.');
                        }
                    }
                 }">
                <h3 class="text-sm font-bold text-slate-900 mb-4 uppercase"><i class="fa-solid fa-building text-indigo-700"></i> Criar Novo Setor</h3>
                <form @submit.prevent="submeterSetor()" class="space-y-3 text-xs font-semibold text-slate-600">
                    <div>
                        <label class="block text-slate-500 mb-1">Nome Oficial da Repartição</label>
                        <input type="text" 
                               x-ref="focoSetor"
                               x-model="dados.nome" 
                               placeholder="Ex: Secretaria de Finanças" 
                               class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg focus:outline-none text-slate-900" required>
                    </div>
                    <div>
                        <label class="block text-slate-500 mb-1">Sigla de Identificação</label>
                        <input type="text" 
                               x-model="dados.sigla" 
                               placeholder="Ex: SEFIN" 
                               class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg focus:outline-none text-slate-900" required>
                    </div>
                    <div class="flex justify-end space-x-2 pt-2 border-t border-slate-100">
                        <button type="button" @click="modalSetorOpen = false" class="px-3 py-1.5 bg-slate-100 text-slate-700 font-bold rounded-lg hover:bg-slate-200">Voltar</button>
                        <button type="submit" class="px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-lg shadow">Injetar Setor</button>
                    </div>
                </form>
            </div>
        </div>

        <div x-show="modalContratoEditarOpen" 
             class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex justify-center items-center z-50 p-4"
             @abrir-editar-contrato.window="
                idEditar = $event.detail.id;
                fetch('/contratos/buscar/' + idEditar).then(res => res.json()).then(res => {
                    dados = { 
                        numero_contrato: res.numero_contrato, 
                        categoria_id: res.categoria_id, 
                        fornecedor_id: res.fornecedor_id, 
                        objeto_resumido: res.objeto_resumido, 
                        valor_total: res.valor_total, 
                        data_inicio: res.data_inicio, 
                        vigencia_meses: res.vigencia_meses, 
                        periodicidade_pagamento: res.periodicidade_pagamento, 
                        setor_id: res.setor_id,
                        necessita_apostilamento: res.necessita_apostilamento || false,
                        data_apostilamento: res.data_apostilamento || ''
                    };
                    
                    valorExibicao = parseFloat(res.valor_total).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    modalContratoEditarOpen = true;
                });
             "
             x-data="{
                idEditar: null,
                valorExibicao: '',
                dados: { numero_contrato: '', categoria_id: '', fornecedor_id: '', objeto_resumido: '', valor_total: '', data_inicio: '', vigencia_meses: '', periodicidade_pagamento: 'Mensal', setor_id: '' },

                aplicarMascaraMoeda(valor) {
                    let apenasNumeros = valor.replace(/\D/g, '');
                    if (!apenasNumeros) { this.valorExibicao = ''; this.dados.valor_total = ''; return; }
                    let valorNumerico = (parseFloat(apenasNumeros) / 100).toFixed(2);
                    this.dados.valor_total = valorNumerico;
                    this.valorExibicao = parseFloat(valorNumerico).toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                },

                async atualizarContrato() {
                    try {
                        let res = await fetch('/contratos/atualizar', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ idEditar: this.idEditar, ...this.dados })
                        });
                        if (res.ok) {
                            alert('Contrato atualizado com sucesso! Alterações computadas na auditoria.');
                            modalContratoEditarOpen = false; idSelecionado = null; window.location.reload();
                        } else {
                            let err = await res.json();
                            alert('Erro: ' + err.erro);
                        }
                    } catch(e) { alert('Falha crítica de comunicação com o servidor.'); }
                }
             }">

            <div class="bg-white rounded-2xl border w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto shadow-2xl relative" @click.away="modalContratoEditarOpen = false">
                <h3 class="text-sm font-bold text-slate-900 mb-4 uppercase flex items-center gap-2">
                    <i class="fa-solid fa-pen-to-square text-amber-500"></i> Editar Contrato (ID: <span x-text="idEditar"></span>)
                </h3>
                
                <form @submit.prevent="unifiedAtualizarContrato()" class="space-y-4 text-xs font-semibold text-slate-600">
                    <div class="grid grid-cols-2 gap-3">
                        <div>
                            <label class="block text-slate-500 mb-1">Nº do Contrato / Processo</label>
                            <input type="text" x-model="dados.numero_contrato" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="block text-slate-500 mb-1">Categoria</label>
                            <select x-model="dados.categoria_id" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 focus:outline-none" required>
                                <% categorias.forEach(cat => { %><option value="<%= cat.id %>"><%= cat.nome %></option><% }) %>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-slate-500 mb-1">Fornecedor / Razão Social</label>
                        <select x-model="dados.fornecedor_id" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 focus:outline-none" required>
                            <% fornecedores.forEach(f => { %><option value="<%= f.id %>"><%= f.razao_social %></option><% }) %>
                        </select>
                    </div>

                    <div>
                        <label class="block text-slate-500 mb-1">Objeto Resumido (Descrição do Escopo)</label>
                        <textarea x-model="dados.objeto_resumido" rows="2" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 focus:outline-none" required></textarea>
                    </div>

                    <div class="grid grid-cols-3 gap-3">
                        <div>
                            <label class="block text-slate-500 mb-1">Valor Global (R$)</label>
                            <input type="text" x-model="valorExibicao" @input="aplicarMascaraMoeda($event.target.value)" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 font-mono text-right focus:outline-none" required>
                        </div>
                        <div>
                            <label class="block text-slate-500 mb-1">Data de Início</label>
                            <input type="date" x-model="dados.data_inicio" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 focus:outline-none" required>
                        </div>
                        <div>
                            <label class="block text-slate-500 mb-1">Vigência (Meses)</label>
                            <input type="number" x-model="dados.vigencia_meses" class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-800 focus:outline-none" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-3 p-3 bg-slate-50 border border-slate-200 rounded-xl items-center">
                        <div class="flex items-center space-x-2">
                            <input type="checkbox" 
                                   id="edit_necessita_apostilamento" 
                                   x-model="dados.necessita_apostilamento" 
                                   @change="if(!dados.necessita_apostilamento) dados.data_apostilamento = ''"
                                   class="w-4 h-4 text-sky-800 border-slate-300 rounded focus:ring-sky-500">
                            <label for="edit_necessita_apostilamento" class="text-xs font-bold text-slate-700 cursor-pointer select-none">
                                <i class="fa-solid fa-stamp text-slate-500 mr-1"></i> Necessita Apostilamento?
                            </label>
                        </div>
                        <div>
                            <label class="block text-slate-500 mb-0.5 text-[11px]">Data Efetiva do Apostilamento</label>
                            <input type="date" 
                                   x-model="dados.data_apostilamento" 
                                   @disabled="!dados.necessita_apostilamento"
                                   :class="!dados.necessita_apostilamento ? 'bg-slate-200 text-slate-400 cursor-not-allowed' : 'bg-white text-slate-800 border-slate-300'"
                                   class="w-full p-2 border rounded-lg focus:outline-none transition-all font-mono"
                                   :required="dados.necessita_apostilamento">
                        </div>
                    </div>

                    <div class="flex justify-end space-x-2 pt-3 border-t border-slate-100">
                        <button type="button" @click="modalContratoEditarOpen = false" class="px-4 py-2 bg-slate-100 text-slate-700 font-bold rounded-lg">Cancelar</button>
                        <button type="submit" class="px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white font-bold rounded-lg shadow">Salvar Alterações</button>
                    </div>
                </form>
            </div>
        </div>
        
        <div x-show="modalMinhaSenhaOpen" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm flex justify-center items-center z-50 p-4" x-transition>
            <div class="bg-white rounded-2xl border w-full max-w-xs p-5 shadow-2xl relative" @click.away="modalMinhaSenhaOpen = false"
                 x-data="{
                    senhaNova: '',
                    async executarTrocaSenha() {
                        if(this.senhaNova.trim().length < 4) {
                            alert('A senha informada é muito curta!');
                            return;
                        }
                        try {
                            let resposta = await fetch('/api/v2/usuario/alterar-senha', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ senhaNova: this.senhaNova })
                            });
                            if (resposta.ok) {
                                alert('Sua senha foi alterada com sucesso! O log de segurança foi registrado.');
                                this.senhaNova = '';
                                modalMinhaSenhaOpen = false;
                            } else {
                                let err = await resposta.json();
                                alert('Erro operacional: ' + err.erro);
                            }
                        } catch(e) {
                            alert('Falha na comunicação de rede.');
                        }
                    }
                 }">
                <h3 class="text-xs font-bold text-slate-900 mb-3 uppercase flex items-center gap-1.5">
                    <i class="fa-solid fa-key text-amber-500"></i> Segurança da Conta
                </h3>
                <p class="text-[11px] text-slate-400 mb-3 font-medium">Modifique sua credencial pessoal de acesso abaixo.</p>
                
                <form @submit.prevent="executarTrocaSenha()" class="space-y-3 text-xs font-semibold text-slate-600">
                    <div>
                        <label class="block text-slate-500 mb-1">Nova Senha</label>
                        <input type="password" 
                               x-model="senhaNova" 
                               placeholder="Mínimo 4 caracteres"
                               class="w-full p-2 bg-slate-50 border border-slate-300 rounded-lg text-slate-900 focus:outline-none" required>
                    </div>
                    <div class="flex justify-end space-x-1.5 pt-2 border-t border-slate-100">
                        <button type="button" @click="modalMinhaSenhaOpen = false" class="px-3 py-1.5 bg-slate-100 text-slate-700 font-bold rounded-lg hover:bg-slate-200">Cancelar</button>
                        <button type="submit" class="px-3 py-1.5 bg-sky-800 hover:bg-sky-900 text-white font-bold rounded-lg shadow-sm">Atualizar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>
</html>