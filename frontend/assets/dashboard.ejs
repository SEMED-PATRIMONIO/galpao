<%- include('partials/header') %>

<div class="flex h-screen bg-slate-100 overflow-hidden" x-data="{ sidebarOpen: true }">
    
    <aside :class="sidebarOpen ? 'w-64' : 'w-20'" class="bg-slate-900 text-slate-300 transition-all duration-300 flex flex-col justify-between border-r border-slate-800 z-20">
        <div>
            <div class="p-4 flex items-center justify-between border-b border-slate-800 bg-slate-950">
                <div class="flex items-center space-x-3" x-show="sidebarOpen">
                    <i class="fa-solid fa-building-shield text-amber-500 text-lg"></i>
                    <span class="font-bold text-sm tracking-wider text-white">Acompanhamento Processual</span>
                </div>
                <button @click="sidebarOpen = !sidebarOpen" class="text-slate-400 hover:text-white mx-auto">
                    <i class="fa-solid fa-bars text-lg"></i>
                </button>
            </div>
            
            <nav class="p-3 space-y-1">
                <a href="/" class="flex items-center space-x-3 px-3 py-2.5 bg-sky-800 text-white rounded-lg font-medium transition-all text-sm">
                    <i class="fa-solid fa-chart-pie w-5 text-center text-base"></i>
                    <span x-show="sidebarOpen">Painel</span>
                </a>

                <% if (perfil === 'operador' || perfil === 'admin') { %>
                <a href="/nova-demanda" class="flex items-center space-x-3 px-3 py-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition-all text-sm">
                    <i class="fa-solid fa-file-circle-plus w-5 text-center text-base"></i>
                    <span x-show="sidebarOpen">Nova</span>
                </a>
                <% } %>

                <% if (perfil === 'admin') { %>
                <a href="/arquivados" class="flex items-center space-x-3 px-3 py-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition-all text-sm">
                    <i class="fa-solid fa-box-archive w-5 text-center text-base"></i>
                    <span x-show="sidebarOpen">Processos Inativos</span>
                </a>
                <% } %>

                <% if (perfil === 'admin') { %>
                <a href="/usuarios" class="flex items-center space-x-3 px-3 py-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition-all text-sm border-t border-slate-800/60 pt-2 mt-2">
                    <i class="fa-solid fa-users-gear w-5 text-center text-base text-amber-500"></i>
                    <span x-show="sidebarOpen" class="text-slate-300 font-semibold">Gestão de Usuários</span>
                </a>
                <% } %>
            </nav>
        </div>

        <div class="p-3 border-t border-slate-800 bg-slate-950 flex items-center justify-between text-xs">
            <div class="flex items-center space-x-2 overflow-hidden" x-show="sidebarOpen">
                <div class="bg-sky-900 text-sky-200 p-2 rounded-lg font-bold"><%= usuario.substring(0,2).toUpperCase() %></div>
                <div class="truncate">
                    <p class="font-semibold text-slate-200 truncate"><%= usuario %></p>
                    <p class="text-slate-500 text-[10px]">Operador</p>
                </div>
                <div x-data="{ modalSenhaOpen: false }">
                    <button @click="modalSenhaOpen = true" class="flex items-center gap-2 px-3 py-2 text-sm text-slate-300 hover:text-white bg-slate-800 hover:bg-slate-700 rounded-lg transition-all shadow-sm">
                        <i class="fa-solid fa-key text-amber-400"></i>
                        <span>Alterar minha Senha</span>
                    </button>

                    <div x-show="modalSenhaOpen" class="fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 z-50" x-cloak>
                        <div class="bg-white rounded-xl p-6 w-full max-w-sm shadow-2xl border border-slate-200" @click.away="modalSenhaOpen = false">
                            <h3 class="text-base font-bold text-slate-800 mb-2 flex items-center gap-2">
                                <i class="fa-solid fa-lock text-sky-700"></i> Nova Senha de Acesso
                            </h3>
                            <p class="text-xs text-slate-500 mb-4">Insira sua nova senha individual. Ela será criptografada imediatamente.</p>
                            
                            <form action="/usuarios/alterar-senha" method="POST" class="space-y-4">
                                <input type="password" name="novaSenha" required class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-600" placeholder="Digite a nova senha">
                                
                                <div class="flex justify-end gap-2 text-xs font-semibold pt-2">
                                    <button type="button" @click="modalSenhaOpen = false" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg transition-all">Cancelar</button>
                                    <button type="submit" class="px-4 py-2 bg-sky-800 hover:bg-sky-900 text-white rounded-lg transition-all shadow-md">Salvar Nova Senha</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div> 
            </div>
            <a href="/logout" class="text-red-400 hover:text-red-300 p-2"><i class="fa-solid fa-right-from-bracket"></i></a>
        </div>
    </aside>

    <div class="flex-1 flex flex-col h-full overflow-hidden">
        
        <section class="bg-white border-b border-slate-200 p-4 shadow-sm z-10">
            <form action="/" method="GET" class="flex flex-col md:flex-row items-end justify-between gap-4">
                
                <div class="grid grid-cols-2 md:grid-cols-5 gap-3 w-full">
                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Ano do Processo</label>
                        <select name="ano" class="w-full px-2.5 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-600">
                            <option value="">Todos os Anos</option>
                            <option value="2026">2025</option>
                            <option value="2025">2026</option>
                            <option value="2024">2027</option>
                            <option value="2026">2028</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Localização Atual</label>
                        <select name="departamento_id" class="w-full px-2.5 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-600">
                            <option value="">Todos os Departamentos</option>
                            <% departamentos.forEach(dept => { %>
                                <option value="<%= dept.id %>"><%= dept.sigla %> - <%= dept.nome %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Status</label>
                        <select name="status" class="w-full px-2.5 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-600">
                            <option value="">Todos os Status</option>
                            <option value="Em análise">Em análise</option>
                            <option value="Concluído">Concluído</option>
                            <option value="Atrasado">Atrasado</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Escola</label>
                        <select name="escola_id" class="w-full px-2.5 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-600">
                            <option value="">Todas as Escolas</option>
                            <% escolas.forEach(esc => { %>
                                <option value="<%= esc.id %>"><%= esc.nome %></option>
                            <% }) %>
                        </select>
                    </div>

                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Buscar por Termo</label>
                        <div class="relative">
                            <input type="text" name="busca" placeholder="Ex: Nome, CPF..." class="w-full px-2.5 py-1.5 bg-slate-50 border border-slate-300 rounded-lg text-xs font-medium text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-600">
                            <button type="submit" class="absolute right-2 top-1.5 text-slate-400 hover:text-sky-800"><i class="fa-solid fa-magnifying-glass"></i></button>
                        </div>
                    </div>
                </div>

                <div class="flex items-center space-x-2 shrink-0">
                    <button type="submit" class="bg-sky-800 text-white text-xs px-3 py-2 font-semibold rounded-lg hover:bg-sky-900 transition-all shadow-sm">Filtrar</button>
                    
                    <div class="bg-slate-900 text-white p-2 rounded-xl text-center min-w-[65px] border border-slate-800 shadow-inner" title="Total de registros encontrados nesta filtragem">
                        <span class="block text-[10px] font-bold uppercase tracking-tight text-slate-400">Total</span>
                        <span class="text-base font-black text-amber-400 font-mono"><%= demandas.length %></span>
                    </div>
                </div>
            </form>
        </section>

        <div class="flex-1 overflow-auto p-4 md:p-6">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden h-full flex flex-col">
                
                <div class="overflow-auto flex-1 relative max-h-full">
                    <table class="w-full text-left border-collapse table-auto">
                        
                        <thead class="bg-slate-50 border-b border-slate-200 sticky top-0 z-10 shadow-sm text-xs text-slate-600 font-bold uppercase tracking-wider">
                            <tr>
                                <th class="p-3 bg-slate-50 sticky left-0 z-20 shadow-[2px_0_5px_rgba(0,0,0,0.05)]">Nº Protocolo</th>
                                <th class="p-3 bg-slate-50 sticky left-[110px] z-20 shadow-[2px_0_5px_rgba(0,0,0,0.05)] border-r border-slate-200">Status</th>
                                <th class="p-3 min-w-[120px]">Data Registro</th>
                                <th class="p-3 min-w-[200px]">Requerente</th>
                                <th class="p-3 min-w-[180px]">Natureza</th>
                                <th class="p-3 min-w-[250px]">Escola Vinculada</th>
                                <th class="p-3 min-w-[300px]">Descrição Resumida</th>
                                <th class="p-3 text-center sticky right-0 bg-slate-50 border-l border-slate-200 z-10">Ações</th>
                            </tr>
                        </thead>
                        
                        <tbody class="text-sm divide-y divide-slate-100 bg-white">
                            <% if (demandas.length === 0) { %>
                                <tr>
                                    <td colspan="8" class="text-center p-8 text-slate-400 font-medium">Nenhum processo localizado para os filtros informados.</td>
                                </tr>
                            <% } else { %>
                                <% demandas.forEach(d => { %>
                                    <tr class="hover:bg-slate-50/80 transition-colors">
                                        
                                        <td class="p-3 bg-white font-mono font-bold text-slate-700 sticky left-0 z-10 shadow-[2px_0_5px_rgba(0,0,0,0.02)]"><%= d.protocolo %></td>
                                        <td class="p-3 bg-white sticky left-[110px] z-10 shadow-[2px_0_5px_rgba(0,0,0,0.02)] border-r border-slate-200">
                                            <span class="px-2.5 py-1 rounded-md text-[11px] font-bold tracking-wide block text-center
                                                <%= d.status === 'Concluído' ? 'bg-sky-100 text-sky-800' : '' %>
                                                <%= d.status === 'Atrasado' ? 'bg-red-100 text-red-800' : '' %>
                                                <%= d.status === 'Em análise' ? 'bg-amber-100 text-amber-800' : '' %>">
                                                <%= d.status %>
                                            </span>
                                        </td>
                                        
                                        <td class="p-3 text-slate-500 font-mono text-xs"><%= new Date(d.data_registro).toLocaleDateString('pt-BR') %></td>
                                        <td class="p-3 font-semibold text-slate-800 truncate max-w-[200px]"><%= d.requerente %></td>
                                        <td class="p-3 text-slate-600"><%= d.nome_natureza || 'Não Informada' %></td>
                                        <td class="p-3 text-xs text-slate-600 max-w-[250px] truncate font-medium"><i class="fa-solid fa-school text-slate-400 mr-1"></i> <%= d.nome_escola || 'Geral/Semed' %></td>
                                        <td class="p-3 text-slate-500 text-xs max-w-[300px] truncate" title="<%= d.descricao_resumida %>"><%= d.descricao_resumida %></td>
                                        
                                        <td class="p-3 text-center sticky right-0 bg-white border-l border-slate-200 z-10 shadow-[-2px_0_5px_rgba(0,0,0,0.02)]">
                                            <div class="flex items-center justify-center space-x-1">
                                                <a href="/demandas/<%= d.id %>/editar" class="text-slate-500 hover:text-sky-800 p-1.5 rounded-lg hover:bg-slate-100" title="Editar / Movimentar"><i class="fa-solid fa-pen-to-square"></i></a>
                                                <form action="/demandas/<%= d.id %>/inativar" method="POST" onsubmit="return confirm('Deseja realmente ocultar este processo do painel ativo?');" class="inline">
                                                    <button type="submit" class="text-slate-400 hover:text-red-600 p-1.5 rounded-lg hover:bg-slate-100" title="Inativar (Ocultar)"><i class="fa-solid fa-eye-slash"></i></button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } %>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>