<%- include('dashboard') %>

<main class="flex-1 overflow-y-auto p-6 bg-slate-100" x-data="{ modalAddOpen: false, modalEditOpen: false, editId: '', editNome: '' }">
    <div class="max-w-4xl mx-auto">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-bold text-slate-800 tracking-tight">Escolas e Clientes</h1>
                <p class="text-xs text-slate-500 mt-0.5">Cadastro unificado de unidades escolares atendidas pela Subsecretaria</p>
            </div>
            <% if (perfil === 'operador' || perfil === 'admin') { %>
            <button @click="modalAddOpen = true" class="bg-sky-800 hover:bg-sky-900 text-white text-xs font-semibold px-4 py-2 rounded-lg shadow transition-all flex items-center gap-2">
                <i class="fa-solid fa-plus"></i> Nova Unidade
            </button>
            <% } %>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <table class="w-full text-left border-collapse text-xs">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-600 font-bold uppercase tracking-wider">
                        <th class="p-4">ID</th>
                        <th class="p-4">Nome da Unidade Escolar</th>
                        <th class="p-4 text-center">Status</th>
                        <th class="p-4 text-right">Ações</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-700">
                    <% lista.forEach(item => { %>
                    <tr class="hover:bg-slate-50/80 transition-colors">
                        <td class="p-4 font-mono text-slate-400">#<%= item.id %></td>
                        <td class="p-4 font-semibold text-slate-800"><%= item.nome %></td>
                        <td class="p-4 text-center">
                            <span class="px-2.5 py-0.5 rounded-full text-[10px] font-bold uppercase <%= item.ativo ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-slate-100 text-slate-500 border border-slate-200' %>">
                                <%= item.ativo ? 'Ativa' : 'Inativa' %>
                            </span>
                        </td>
                        <td class="p-4 text-right space-x-1">
                            <button @click="modalEditOpen = true; editId = '<%= item.id %>'; editNome = '<%= item.nome %>'" class="text-slate-500 hover:text-sky-700 p-1"><i class="fa-solid fa-pen-to-square"></i></button>
                            <% if (perfil === 'admin') { %>
                            <form action="/escolas/<%= item.id %>/status" method="POST" class="inline">
                                <input type="hidden" name="ativo" value="<%= item.ativo %>">
                                <button type="submit" class="<%= item.ativo ? 'text-red-500 hover:text-red-700' : 'text-emerald-500 hover:text-emerald-700' %> p-1">
                                    <i class="fa-solid <%= item.ativo ? 'fa-ban' : 'fa-circle-check' %>"></i>
                                </button>
                            </form>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <div x-show="modalAddOpen" class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-50" x-cloak>
        <div class="bg-white rounded-xl p-6 w-full max-w-md shadow-xl border border-slate-200" @click.away="modalAddOpen = false">
            <h3 class="text-base font-bold text-slate-800 mb-4">Cadastrar Escola</h3>
            <form action="/escolas" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-600 mb-1">Nome Oficial da Unidade</label>
                    <input type="text" name="nome" required placeholder="Ex: E.M. Professor Roberto Silvares" class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-sm text-slate-800 focus:ring-2 focus:ring-sky-600 outline-none">
                </div>
                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" @click="modalAddOpen = false" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg text-xs font-medium">Cancelar</button>
                    <button type="submit" class="px-4 py-2 bg-sky-800 hover:bg-sky-900 text-white rounded-lg text-xs font-medium shadow-md">Salvar</button>
                </div>
            </form>
        </div>
    </div>

    <div x-show="modalEditOpen" class="fixed inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 z-50" x-cloak>
        <div class="bg-white rounded-xl p-6 w-full max-w-md shadow-xl border border-slate-200" @click.away="modalEditOpen = false">
            <h3 class="text-base font-bold text-slate-800 mb-4">Editar Unidade Escolar</h3>
            <form :action="'/escolas/' + editId + '/editar'" method="POST" class="space-y-4">
                <div>
                    <label class="block text-xs font-semibold text-slate-600 mb-1">Nome da Escola</label>
                    <input type="text" name="nome" x-model="editNome" required class="w-full px-3 py-2 bg-slate-50 border border-slate-300 rounded-lg text-sm text-slate-800 focus:ring-2 focus:ring-sky-600 outline-none">
                </div>
                <div class="flex justify-end gap-2 pt-2">
                    <button type="button" @click="modalEditOpen = false" class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg text-xs font-medium">Cancelar</button>
                    <button type="submit" class="px-4 py-2 bg-sky-800 hover:bg-sky-900 text-white rounded-lg text-xs font-medium shadow-md">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</main>
</div>
</body>
</html>