<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>SEMED Contratos | Autenticação</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-slate-900 flex items-center justify-center h-screen antialiased">
    <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-sm border border-slate-100">
        <h2 class="text-slate-800 font-black text-center text-sm uppercase tracking-wider mb-2">Painel de Contratos SEMED</h2>
        <p class="text-slate-400 text-center text-xs font-medium mb-6">Insira suas credenciais de acesso</p>
        
        <% if (erro) { %>
            <div class="bg-rose-50 text-rose-700 border border-rose-200 text-xs font-bold p-3 rounded-lg mb-4 text-center">
                <%= erro %>
            </div>
        <% } %>

        <form action="/api/v2/auth/login" method="POST" class="space-y-4 text-xs font-semibold text-slate-600">
            <div>
                <label class="block text-slate-500 mb-1">Nome do Usuário</label>
                <input type="text" name="nome" placeholder="Ex: MYTSE" class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:outline-none" required>
            </div>
            <div>
                <label class="block text-slate-500 mb-1">Senha de Acesso</label>
                <input type="password" name="senha" class="w-full p-2.5 bg-slate-50 border border-slate-300 rounded-lg focus:outline-none" required>
            </div>
            <button type="submit" class="w-full py-2.5 bg-sky-800 hover:bg-sky-900 text-white font-bold rounded-lg shadow-md transition-all uppercase tracking-wider">Entrar no Sistema</button>
        </form>
    </div>
</body>
</html>