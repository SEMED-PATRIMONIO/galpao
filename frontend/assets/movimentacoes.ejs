<%- include('dashboard') %>

<main class="flex-1 overflow-y-auto p-6 bg-slate-100">
    <div class="max-w-6xl mx-auto">
        <div class="mb-6">
            <h1 class="text-xl font-bold text-slate-800 tracking-tight">Trilha de Auditoria e Movimentações</h1>
            <p class="text-xs text-slate-500 mt-0.5">Histórico imutável de alterações em registros e fluxos internos de processos</p>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
            <table class="w-full text-left border-collapse text-xs">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200 text-slate-600 font-bold uppercase tracking-wider">
                        <th class="p-4">Data/Hora</th>
                        <th class="p-4">Processo</th>
                        <th class="p-4">Operador Responsável</th>
                        <th class="p-4">Campo Modificado</th>
                        <th class="p-4">Valor Anterior</th>
                        <th class="p-4">Novo Valor</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-slate-600">
                    <% if (logs.length === 0) { %>
                    <tr>
                        <td colspan="6" class="p-8 text-center text-slate-400 font-medium">Nenhuma movimentação ou alteração foi registrada até o momento.</td>
                    </tr>
                    <% } %>
                    <% logs.forEach(log => { %>
                    <tr class="hover:bg-slate-50/50 transition-colors">
                        <td class="p-4 whitespace-nowrap font-mono text-slate-500">
                            <%= new Date(log.data_alteracao).toLocaleString('pt-BR') %>
                        </td>
                        <td class="p-4 font-bold text-slate-800"><%= log.numero_processo %></td>
                        <td class="p-4 font-medium text-slate-700">
                            <span class="flex items-center gap-1.5">
                                <i class="fa-solid fa-user-check text-slate-400"></i> <%= log.nome_usuario || 'Sistema' %>
                            </span>
                        </td>
                        <td class="p-4 font-mono text-sky-700 bg-sky-50/40 font-semibold"><%= log.campo_alterado %></td>
                        <td class="p-4 text-red-600 line-through max-w-xs truncate"><%= log.depto_antigo || log.valor_antigo || 'Vazio' %></td>
                        <td class="p-4 text-emerald-600 font-semibold max-w-xs truncate"><%= log.depto_novo || log.valor_novo %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</main>
</div>
</body>
</html>