<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Ouvidoria Geral</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-slate-900 flex items-center justify-center min-h-screen p-4">
    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md border border-slate-200">
        <div class="text-center mb-6">
            <div class="bg-sky-100 text-sky-900 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-3 shadow-sm">
                <i class="fa-solid fa-lock text-2xl"></i>
            </div>
            <h1 class="text-xl font-bold text-slate-800 tracking-tight">Painel Institucional</h1>
            <p class="text-xs text-slate-500 mt-1">Insira suas credenciais para gerenciar processos</p>
        </div>

        <% if (erro) { %>
            <div class="bg-red-50 text-red-700 p-3 rounded-lg text-xs font-semibold mb-4 border border-red-200 flex items-center">
                <i class="fa-solid fa-circle-exclamation mr-2"></i> <%= erro %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-slate-600 uppercase mb-1">Nome de Usuário</label>
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400"><i class="fa-solid fa-user"></i></span>
                    <input type="text" name="username" required class="w-full pl-9 pr-3 py-2.5 bg-slate-50 border border-slate-300 text-sm rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-600 transition-all text-slate-800" placeholder="Ex: joao.silva">
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-600 uppercase mb-1">Senha de Acesso</label>
                <input type="password" name="senha" required class="w-full px-3 py-2.5 bg-slate-50 border border-slate-300 text-sm rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-600 transition-all text-slate-800" placeholder="••••••••">
            </div>
            <button type="submit" class="w-full bg-sky-800 text-white font-semibold text-sm py-2.5 rounded-lg hover:bg-sky-900 transition-all shadow-md">
                Autenticar no Sistema
            </button>
        </form>
    </div>
</body>
</html>