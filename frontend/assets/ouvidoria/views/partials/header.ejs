<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Acompanhamento Processual</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/tailwind.css">
    <style>
        .modo-smartphone { max-width: 450px; margin: 0 auto; border: 12px solid #333; border-radius: 40px; height: 920px; overflow-y: auto; }
        .modo-desktop { max-width: 100%; margin: 0; border: none; }
    </style>
</head>
<body class="bg-slate-100 text-slate-800 font-sans" x-data="{ viewMode: localStorage.getItem('preferredView') || 'desktop' }" :class="viewMode === 'smartphone' ? 'modo-smartphone bg-white my-4 shadow-2xl' : 'modo-desktop'">
    
    <header>
        <div class="flex items-center space-x-4">
            <div class="flex bg-sky-800 p-1 rounded-lg text-xs border border-sky-700 shadow-inner">
                <button @click="viewMode = 'desktop'; localStorage.setItem('preferredView', 'desktop')" :class="viewMode === 'desktop' ? 'bg-white text-sky-900 font-bold' : 'text-sky-200'" class="px-3 py-1 rounded-md transition-all">
                    <i class="fa-solid fa-desktop mr-1"></i> Monitor
                </button>
                <button @click="viewMode = 'smartphone'; localStorage.setItem('preferredView', 'smartphone')" :class="viewMode === 'smartphone' ? 'bg-white text-sky-900 font-bold' : 'text-sky-200'" class="px-3 py-1 rounded-md transition-all">
                    <i class="fa-solid fa-mobile-screen-button mr-1"></i> Smartphone
                </button>
            </div>
            
            <a href="/logout" class="text-sky-200 hover:text-white text-xs font-medium bg-sky-950/40 px-2.5 py-1.5 rounded-lg transition-all" title="Sair do Sistema">
                <i class="fa-solid fa-right-from-bracket"></i>
            </a>
        </div> 
    </header>