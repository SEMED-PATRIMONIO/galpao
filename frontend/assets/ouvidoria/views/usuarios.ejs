<%- include('partials/header') %>

<div class="flex h-screen bg-slate-100 overflow-hidden" x-data="{ sidebarOpen: true }">
    
    <aside :class="sidebarOpen ? 'w-64' : 'w-20'" class="bg-slate-900 text-slate-300 transition-all duration-300 flex flex-col justify-between border-r border-slate-800 z-20">
        <div>
            <div class="p-4 flex items-center justify-between border-b border-slate-800 bg-slate-950">
                <div class="flex items-center space-x-3" x-show="sidebarOpen">
                    <i class="fa-solid fa-building-shield text-amber-500 text-lg"></i>
                    <span class="font-bold text-sm tracking-wider text-white">SOG - OUVIDORIA</span>
                </div>
                <button @click="sidebarOpen = !sidebarOpen" class="text-slate-400 hover:text-white mx-auto">
                    <i class="fa-solid fa-bars text-lg"></i>
                </button>
            </div>
            
            <nav class="p-3 space-y-1">
                <a href="/" class="flex items-center space-x-3 px-3 py-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition-all text-sm">
                    <i class="fa-solid fa-chart-pie w-5 text-center text-base"></i>
                    <span x-show="sidebarOpen">Painel de Demandas</span>
                </a>

                <% if (perfil === 'operador' || perfil === 'admin') { %>
                <a href="/nova-demanda" class="flex items-center space-x-3 px-3 py-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition-all text-sm">
                    <i class="fa-solid fa-file-circle-plus w-5 text-center text-base"></i>
                    <span x-show="sidebarOpen">Nova Demanda</span>
                </a>
                <% } %>

                <% if (perfil === 'admin') { %>
                <a href="/arquivados" class="flex items-center space-x-3 px-3 py-2.5 text-slate-400 hover:bg-slate-800 hover:text-white rounded-lg transition-all text-sm">
                    <i class="fa-solid fa-box-archive w-5 text-center text-base"></i>
                    <span x-show="sidebarOpen">Processos Inativos</span>
                </a>
                <% } %>

                <% if (perfil === 'admin') { %>
                <a href="/usuarios" class="flex items-center space-x-3 px-3 py-2.5 bg-sky-800 text-white rounded-lg font-medium transition-all text-sm border-t border-slate-800/60 pt-2 mt-2">
                    <i class="fa-solid fa-users-gear w-5 text-center text-base text-amber-400"></i>
                    <span x-show="sidebarOpen" class="font-semibold">Gestão de Usuários</span>
                </a>
                <% } %>
            </nav>
        </div>

        <div class="p-3 border-t border-slate-800 bg-slate-950 flex items-center justify-between text-xs">
            <div class="flex items-center space-x-2 overflow-hidden" x-show="sidebarOpen">
                <div class="bg-sky-900 text-sky-200 p-2 rounded-lg font-bold">
                    <%= usuario ? usuario.substring(0,2).toUpperCase() : 'AD' %>
                </div>
                <div class="truncate">
                    <p class="font-semibold text-slate-200 truncate"><%= usuario %></p>
                    <p class="text-slate-500 text-[10px] uppercase tracking-wider font-mono"><%= perfil %></p>
                </div>
            </div>
            <a href="/logout" class="text-red-400 hover:text-red-300 p-2" title="Sair do Sistema"><i class="fa-solid fa-right-from-bracket"></i></a>
        </div>
    </aside>

    <div class="flex-1 flex flex-col h-full overflow-hidden p-4 md:p-6 space-y-4">
        
        <div class="flex justify-between items-center bg-white p-4 rounded-xl border border-slate-200 shadow-sm shrink-0">
            <div>
                <h2 class="text-base font-bold text-slate-800 flex items-center">
                    <i class="fa-solid fa-users-gear text-sky-800 mr-2 bg-sky-50 p-2 rounded-lg"></i>
                    Controle de Acesso Funcional (RBAC)
                </h2>
                <p class="text-xs text-slate-500">Cadastre novos operadores e defina restrições baseadas na função técnica.</p>
            </div>
        </div>

        <% if (msg) { %>
            <div class="bg-emerald-50 text-emerald-800 p-3 rounded-lg text-xs font-semibold border border-emerald-200 shrink-0 flex items-center">
                <i class="fa-solid fa-circle-check text-emerald-600 mr-2 text-sm"></i> <%= msg %>
            </div>
        <% } %>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 flex-1 overflow-hidden w-full">
            
            <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm h-fit shrink-0">
                <h3 class="font-bold text-slate-700 text-xs uppercase tracking-wider mb-4 border-b border-slate-100 pb-2">Novo Funcionário</h3>
                
                <form action="/usuarios" method="POST" class="space-y-3">
                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Nome Completo</label>
                        <input type="text" name="nome" required placeholder="Ex: Carlos Alberto da Silva" class="w-full px-3 py-2 bg-slate-50 border border-slate-300 text-xs rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-600 font-medium text-slate-700">
                    </div>
                    
                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Nome de Usuário (Login)</label>
                        <input type="text" name="username" required placeholder="Ex: carlos.silva" class="w-full px-3 py-2 bg-slate-50 border border-slate-300 text-xs rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-600 font-mono text-slate-700">
                    </div>
                    
                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Senha Inicial</label>
                        <input type="password" name="senha" required placeholder="••••••••" class="w-full px-3 py-2 bg-slate-50 border border-slate-300 text-xs rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-600 text-slate-700">
                    </div>
                    
                    <div>
                        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Perfil de Permissão</label>
                        <select name="perfil" required class="w-full px-3 py-2 bg-slate-50 border border-slate-300 text-xs rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-600 font-semibold text-slate-700">
                            <option value="leitor">Leitor (Apenas Visualiza os Registros)</option>
                            <option value="operador">Operador (Insere e Modifica Processos)</option>
                            <option value="admin">Administrador (Acesso Total + Usuários)</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="w-full bg-sky-800 text-white font-bold text-xs py-2.5 rounded-lg hover:bg-sky-900 transition-all shadow-sm mt-2">
                        <i class="fa-solid fa-user-plus mr-1"></i> Salvar Funcionário
                    </button>
                </form>
            </div>

            <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden flex flex-col h-full">
                
                <div class="p-3 bg-slate-50 border-b border-slate-100 flex justify-between items-center shrink-0">
                    <span class="text-xs font-bold text-slate-600 uppercase tracking-wider">Operadores Cadastrados</span>
                    <span class="bg-slate-200 text-slate-700 font-mono text-[11px] font-bold px-2 py-0.5 rounded-md"><%= listaUsuarios.length %></span>
                </div>

                <div class="overflow-auto flex-1 relative max-h-full">
                    <table class="w-full text-left border-collapse text-xs">
                        <thead class="bg-slate-50 border-b border-slate-200 font-bold text-slate-600 uppercase sticky top-0 z-10">
                            <tr>
                                <th class="p-3 bg-slate-50">Nome Funcionário</th>
                                <th class="p-3 bg-slate-50">Usuário</th>
                                <th class="p-3 bg-slate-50 text-center">Nível / Perfil</th>
                                <th class="p-3 bg-slate-50 text-center">Status</th>
                                <th class="p-3 bg-slate-50 text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-white">
                            <% listaUsuarios.forEach(u => { %>
                                <tr class="hover:bg-slate-50/50 transition-colors <%= !u.ativo ? 'bg-slate-50/70 text-slate-400' : '' %>">
                                    <td class="p-3 font-semibold <%= u.ativo ? 'text-slate-800' : 'text-slate-400 line-through' %>">
                                        <%= u.nome %>
                                    </td>
                                    <td class="p-3 font-mono text-slate-500 font-medium"><%= u.username %></td>
                                    <td class="p-3 text-center">
                                        <span class="px-2.5 py-0.5 rounded-md font-bold uppercase text-[10px] tracking-wide block mx-auto w-fit
                                            <%= u.perfil === 'admin' ? 'bg-purple-100 text-purple-800' : '' %>
                                            <%= u.perfil === 'operador' ? 'bg-blue-100 text-blue-800' : '' %>
                                            <%= u.perfil === 'leitor' ? 'bg-slate-100 text-slate-600' : '' %>">
                                            <%= u.perfil %>
                                        </span>
                                    </td>
                                    <td class="p-3 text-center font-bold">
                                        <% if (u.ativo) { %>
                                            <span class="text-emerald-600 flex items-center justify-center"><span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5 animate-pulse"></span> Ativo</span>
                                        <% } else { %>
                                            <span class="text-red-400 flex items-center justify-center"><span class="w-1.5 h-1.5 rounded-full bg-red-400 mr-1.5"></span> Inativo</span>
                                        <% } %>
                                    </td>
                                    <td class="p-3 text-center">
                                        <form action="/usuarios/<%= u.id %>/status" method="POST" onsubmit="return confirm('Deseja alterar o status de acesso deste usuário?');">
                                            <input type="hidden" name="atual" value="<%= u.ativo %>">
                                            <button type="submit" class="px-2.5 py-1 rounded-md border font-bold text-[10px] uppercase transition-all shadow-sm
                                                <%= u.ativo ? 'border-red-200 text-red-600 hover:bg-red-50 bg-white' : 'border-emerald-200 text-emerald-600 hover:bg-emerald-50 bg-white' %>">
                                                <%= u.ativo ? 'Inativar Bloquear' : 'Reativar Liberar' %>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>

<%- include('partials/footer') %>